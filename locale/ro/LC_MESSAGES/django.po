# Plugin descriptions (used in dashboard via _(plugin.description))
msgid "Visual noise level monitor for classroom with dual RGB LED feedback"
msgstr "Monitor vizual de nivel de zgomot pentru clasă cu feedback RGB LED dublu"

msgid ""
"SPI TFT LCD display support for ILI9341 driver. "
"Shows a smiling face on startup with web-based controls."
msgstr ""
"Suport afișaj LCD TFT SPI pentru driver ILI9341. "
"Afișează o față zâmbitoare la pornire cu comenzi web."

msgid ""
"Text-to-Speech classroom routines with USB presenter support for activities"
msgstr ""
"Rutine de clasă text-to-speech cu suport prezentator USB pentru activități"

msgid ""
"Play musical notes by touching conductive materials connected to GPIO pins. "
"Supports bananas, foil, copper tape, and other conductive items."
msgstr ""
"Cântă note muzicale atingând materiale conductive conectate la pinii GPIO. "
"Suportă banane, folie, bandă de cupru și alte obiecte conductive."

